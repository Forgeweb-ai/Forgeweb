# forge-server environment variables
# Copy to .env and fill in secrets before starting

# ── Database ──────────────────────────────────────────────────────────────────
# Local Supabase Postgres (dev.sh boots this via `supabase start`):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres
# Hosted Supabase (prod) example — replace with your project's pooler URL:
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Docker ────────────────────────────────────────────────────────────────────
DOCKER_NETWORK=forge-net
# CONTAINER_IMAGE=forge-runner:latest     # default

# ── AI ────────────────────────────────────────────────────────────────────────
# Forge is BYOK at the USER layer. Provider keys are entered in-app, encrypted
# with Fernet in user_provider_keys, and injected per-request by the resolver.
# Nothing to set here. (See root .env.example for the full explanation.)

# ── Routing ───────────────────────────────────────────────────────────────────
# Traefik routes *.${PREVIEW_DOMAIN} to project containers via Docker labels.
# Local: preview.lvh.me (wildcard-resolves to 127.0.0.1, no DNS setup).
# Prod:  preview.forge.com (real wildcard DNS, https).
PREVIEW_DOMAIN=preview.lvh.me
PREVIEW_SCHEME=http

# ── Domains (used by Traefik labels) ─────────────────────────────────────────
API_DOMAIN=api.forge.localhost
APP_DOMAIN=app.forge.localhost

# ── Sleep settings ────────────────────────────────────────────────────────────
SLEEP_CHECK_INTERVAL=60          # seconds between idle checks
IDLE_TTL=600                     # stop container after 10 min idle

# ── Supabase encryption ───────────────────────────────────────────────────────
# Optional: override the default key derived from JWT_SECRET
# Must be exactly 32 ASCII chars base64url-encoded
# SUPABASE_ENCRYPT_KEY=
