# ── Forge Environment Config ──────────────────────────────────────────────────
# Copy this to .env and fill in your values.

# ── Model Backend ─────────────────────────────────────────────────────────────
# "ai"       = Direct provider API: DeepSeek, OpenAI/ChatGPT, Gemini, Anthropic, custom OpenAI-compatible
# "together" = Together AI API (fast, no GPU needed, great for dev)
# "local"    = llama.cpp local model file (offline, mobile-ready)
MODEL_BACKEND=ai

# ── Direct AI Provider ────────────────────────────────────────────────────────
# Switch providers by changing these values and restarting the backend.
# AI_PROVIDER options: deepseek, openai, gemini, anthropic, custom
AI_PROVIDER=deepseek
AI_API_KEY=your_provider_api_key_here
AI_MODEL=deepseek-v4-flash
# DeepSeek V4 defaults to thinking mode; keep disabled for code/file streaming.
AI_THINKING=disabled
# AI_BASE_URL is only needed for AI_PROVIDER=custom or provider-compatible proxies.
# AI_BASE_URL=https://api.example.com/v1

# Examples:
# DeepSeek direct:
#   AI_PROVIDER=deepseek
#   AI_MODEL=deepseek-v4-flash
# OpenAI / ChatGPT:
#   AI_PROVIDER=openai
#   AI_MODEL=gpt-4.1
# Gemini:
#   AI_PROVIDER=gemini
#   AI_MODEL=gemini-2.5-pro
# Anthropic:
#   AI_PROVIDER=anthropic
#   AI_MODEL=claude-sonnet-4-5-20250929

# ── Together AI ───────────────────────────────────────────────────────────────
# Get your key at https://api.together.xyz
TOGETHER_API_KEY=your_together_api_key_here

# Model for code generation (production: Phi-3.5 Mini fine-tuned)
# During dev, use the 405B teacher for best quality
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
# TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-405B-Instruct-Turbo   # teacher model
# TOGETHER_MODEL=microsoft/Phi-3.5-mini-instruct                  # student model

# ── Local Model (llama.cpp) ───────────────────────────────────────────────────
# Path to your fine-tuned GGUF file
LOCAL_MODEL_PATH=./models/forge-phi3.5-Q4_K_M.gguf
LOCAL_CONTEXT_SIZE=8192
LOCAL_THREADS=4
LOCAL_GPU_LAYERS=0     # Set > 0 if you have a GPU

# ── Data Generation ───────────────────────────────────────────────────────────
# Teacher model used to generate synthetic training data (must allow it)
TEACHER_MODEL=meta-llama/Meta-Llama-3.1-405B-Instruct-Turbo
TEACHER_API_KEY=your_together_api_key_here

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Run: createdb forge  (once, to create the database)
# Tables are created automatically on first startup via init_db()
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/forge

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
DEBUG=true

# ── Telemetry (privacy-first, opt-in) ────────────────────────────────────────
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=https://your-analytics.example.com
