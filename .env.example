# ── Forge V2 Environment Variables ────────────────────────────────────────────
# Copy to .env and fill in values. Never commit .env to git.

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://forge:your_secure_password_here@postgres:5432/forge

# ── Auth (JWT) ─────────────────────────────────────────────────────────────────
JWT_SECRET=generate_with__openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080   # 7 days

# ── Domains ────────────────────────────────────────────────────────────────────
APP_DOMAIN=app.forge.com           # Forge UI
API_DOMAIN=api.forge.com           # Forge Backend
PREVIEW_DOMAIN=preview.forge.com   # Project containers: {project_id}.preview.forge.com
API_URL=https://api.forge.com

# ── OpenCode ───────────────────────────────────────────────────────────────────
OPENCODE_URL=http://opencode:7777  # Internal only — not exposed to internet

# ── AI providers ───────────────────────────────────────────────────────────────
# Forge is BYOK at the USER layer, not the deploy layer.
#
# Users add their own provider keys from in-app Settings → API Keys. Keys are
# Fernet-encrypted in the user_provider_keys table and only decrypted on the
# exact provider request that needs them. The per-user resolver (forge-server
# opencode_proxy + opencode's ForgeMode middleware) injects the key on every
# request — opencode never reads provider keys from env in Forge mode.
#
# Default model is opencode zen's DeepSeek V4 Flash Free — no key required to
# start building. Users add a key only if they want a paid model.
#
# DO NOT add ANTHROPIC_API_KEY / OPENAI_API_KEY / etc. here. The deploy layer
# does not need them; setting them here re-introduces the "platform key leaks
# into user sessions" path we explicitly removed.

# ── Storage ────────────────────────────────────────────────────────────────────
FORGE_DATA_ROOT=/forge-data        # Where user workspaces live on the server

# ── Docker ─────────────────────────────────────────────────────────────────────
# Docker socket is mounted via docker-compose.yml volume.
# Project containers join the forge-net network automatically.

# ── Dev overrides (local development without Docker) ──────────────────────────
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/forge
# OPENCODE_URL=http://localhost:7777
# FORGE_DATA_ROOT=./local-data
# PREVIEW_DOMAIN=preview.localhost
