# syntax=docker/dockerfile:1
# Forge build of the vendored opencode fork
# ===========================================
# Runs opencode from source under bun (the project's declared package
# manager). We do NOT use the upstream packages/opencode/Dockerfile because
# that expects a pre-built native binary in dist/; we want to run our
# patched TypeScript directly so Phase 2 (Auth.Override + Auth.ForgeMode +
# forge-auth middleware + per-request key suppression in provider.ts) is
# actually executed.
#
# Build context must be the opencode/ directory:
#   docker build -f opencode/Dockerfile.forge -t forge-opencode ./opencode
#
# Image size is dominated by the @ai-sdk/* dependency surface and is
# accepted as the cost of running from source. If image size becomes a
# scale concern (it's hundreds of MB), follow up with a `bun build` pass
# that produces a single bundled file and ship that instead — same patch
# code, smaller runtime.

FROM oven/bun:1.3.14

# Match the runtime tooling the upstream Dockerfile assumes plus python3
# (the ui-ux-pro-max skill's reasoning engine needs it for the design-
# system generator's scripts/search.py).
#
# build-essential = gcc + g++ + make + libc6-dev — required because
# tree-sitter-* packages ship native bindings compiled by node-gyp during
# `bun install`.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential python3 python3-pip ripgrep git curl jq patch \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opencode

# Manifest layer first so bun install caches across rebuilds that only
# touch source files.
COPY package.json bun.lock bunfig.toml turbo.json tsconfig.json ./
COPY packages ./packages
# patches/ holds bun patchedDependencies referenced in package.json.
COPY patches ./patches

# Strip ../forge-ui from workspaces, strip patchedDependencies (to bypass Bun's buggy NAS patch applier),
# and strip scripts.prepare (husky git hooks don't belong in container builds).
RUN jq '.workspaces.packages |= map(select(. != "../forge-ui")) | del(.patchedDependencies) | del(.scripts.prepare)' package.json > package.tmp.json \
 && mv package.tmp.json package.json \
 && rm -rf packages/desktop

# Strip bunfig.toml's minimumReleaseAge before install.
RUN sed -i '/minimumReleaseAge/d' bunfig.toml || true

# Install workspace deps cleanly without bun's patch applier engine
RUN --mount=type=tmpfs,target=/root/.bun/install/cache \
    bun install --no-save || bun install --no-save

# Apply patches explicitly using POSIX GNU patch for 100% NAS/cloud/mac filesystem compatibility
RUN patch -p1 -l -d node_modules/@ai-sdk/xai < patches/@ai-sdk-xai@3.0.82.patch \
 && patch -p1 -l -d node_modules/@npmcli/agent < patches/@npmcli-agent@4.0.0.patch \
 && patch -p1 -l -d node_modules/@silvia-odwyer/photon-node < patches/@silvia-odwyer-photon-node@0.3.4.patch \
 && patch -p1 -l -d node_modules/@standard-community/standard-openapi < patches/@standard-community-standard-openapi@0.2.9.patch \
 && patch -p1 -l -d node_modules/solid-js < patches/solid-js@1.9.10.patch

# Bun's isolated linker doesn't fully materialise every transitive dep into
# per-workspace-member node_modules — registry deps often end up only at
# the workspace root /opencode/node_modules. Bun's runtime loader resolves
# relative to the script's directory and DOESN'T walk up to the workspace
# root, so a runtime ENOENT fires for any registry dep that landed only at
# root. Bridge with explicit symlinks from root into every workspace
# member's node_modules so module resolution finds everything where the
# loader looks (yargs for packages/opencode, effect for packages/core, etc.).
#
# Find every workspace member by looking for package.json under packages/
# (one and two levels deep — sdk/js is nested). For each, mkdir its
# node_modules and symlink every entry from /opencode/node_modules into it.
# Handles regular packages and @scoped/* packages.
RUN set -e;                                                                 for pkg_json in packages/*/package.json packages/*/*/package.json; do        [ -f "$pkg_json" ] || continue;                                            member_dir=$(dirname "$pkg_json");                                         mkdir -p "$member_dir/node_modules";                                       (cd "$member_dir/node_modules";                                              for src in /opencode/node_modules/*; do                                      name=$(basename "$src");                                                   case "$name" in                                                              "") continue ;;                                                          @*)                                                                          mkdir -p "$name";                                                          for sub in "$src"/*; do                                                      subname=$(basename "$sub");                                                [ ! -e "$name/$subname" ] && ln -sf "$sub" "$name/$subname" || true;       done ;;                                                                  *)                                                                           [ ! -e "$name" ] && ln -sf "$src" "$name" || true ;;                       esac;                                                                   done);                                                                     echo "  linked into $member_dir/node_modules";                          done

# Runtime sanity check covering BOTH the package.json'd workspace members
# the runtime is known to touch and the specific registry deps that ENOENT'd.
RUN set -e;     for check in       "packages/opencode/node_modules/yargs"       "packages/opencode/node_modules/minimatch"       "packages/opencode/node_modules/@ai-sdk/openai"       "packages/opencode/node_modules/@ai-sdk/anthropic"       "packages/opencode/node_modules/@smithy/eventstream-codec"       "packages/core/node_modules/effect"       "packages/llm/node_modules/effect"; do       if [ -e "$check" ]; then         echo "PRESENT  $check";       else         echo "MISSING  $check — runtime will ENOENT";         exit 1;       fi;     done

# Fail fast if the Phase 2 patches aren't in the build context. Prevents a
# silent regression where someone builds the image off a clean upstream
# checkout and re-leaks platform keys.
RUN test -f packages/opencode/src/auth/index.ts \
 && test -f packages/opencode/src/server/routes/instance/httpapi/middleware/forge-auth.ts \
 && grep -q "ForgeMode" packages/opencode/src/auth/index.ts \
 && grep -q "forgeAuthLayer" packages/opencode/src/server/routes/instance/httpapi/server.ts \
 && grep -q "forgeMode" packages/opencode/src/provider/provider.ts \
 || (echo "FATAL: Phase 2 patches missing — refusing to build a leaky image" && exit 1)

ENV NODE_ENV=production
EXPOSE 7777

# Default command — docker-compose overrides with the same line for clarity
# at the call site.
CMD ["bun", "run", "--conditions=browser", "packages/opencode/src/index.ts", "serve", "--port", "7777", "--hostname", "0.0.0.0"]
